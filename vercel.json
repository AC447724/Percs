{
  "version": 2,
  "rewrites": [
    {
      "source": "/assets/u/:slug",
      "destination": "/api/assets/[slug]"
    },
    { 
      "source": "/login", 
      "destination": "/api/auth/login" 
    },
    { 
      "source": "/api/callback", 
      "destination": "/api/auth/callback" 
    },
    {
      "source": "/api/petition",
      "destination": "/api/petition.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*).js",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
